POSTGRES_DB=rgm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# JWT (obrigatorio — sem default em producao)
JWT_SECRET=rgm-default-secret-key-for-development-must-be-at-least-32-bytes

# Spring profile (dev ou prod)
SPRING_PROFILES_ACTIVE=dev
